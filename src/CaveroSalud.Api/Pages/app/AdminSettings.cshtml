@page "/app/admin/settings"
@model CaveroSalud.Api.Pages.App.AdminSettingsModel
@{
  ViewData["Title"] = "Configuración del sitio";
}

<div class="container py-5">
  @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
  {
    <div class="alert alert-success" role="alert">@Model.StatusMessage</div>
  }

  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h3 mb-0">Configuración del sitio</h1>
      <div class="small text-muted">Edita el contenido visible en la página de inicio</div>
    </div>
    <div class="d-flex gap-2">
      <a class="btn btn-outline-primary" href="/app/admin/specialities">Sección especialidades</a>
      <a class="btn btn-outline-secondary" href="/app/admin">Volver al panel</a>
    </div>
  </div>

  <form method="post" class="row g-4">
    <div class="col-lg-8">
      <div class="card shadow-sm h-100">
        <div class="card-body">
          <h5 class="card-title mb-4">Contenido principal</h5>
          <div class="row g-3">
            <div class="col-12">
              <label asp-for="Title" class="form-label">Título</label>
              <input asp-for="Title" class="form-control" />
            </div>
            <div class="col-12">
              <label asp-for="TagLine" class="form-label">Eslogan</label>
              <input asp-for="TagLine" class="form-control" />
            </div>
            <div class="col-12">
              <label asp-for="Description" class="form-label">Descripción</label>
              <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            </div>
            <div class="col-md-6">
              <label asp-for="Address" class="form-label">Dirección</label>
              <input asp-for="Address" class="form-control" />
            </div>
            <div class="col-md-6">
              <label asp-for="Phone" class="form-label">Teléfono</label>
              <input asp-for="Phone" class="form-control" />
            </div>
            <div class="col-md-6">
              <label asp-for="Email" class="form-label">Correo</label>
              <input asp-for="Email" type="email" class="form-control" />
            </div>
            <div class="col-12">
              <small class="text-muted">Estos datos alimentan el título, eslogan y descripción de la página principal.</small>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="card shadow-sm h-100">
        <div class="card-body">
          <h5 class="card-title mb-4">Vista previa del inicio</h5>
          <div class="mb-3">
            <div class="small text-muted">Título</div>
            <div class="fw-semibold">@Model.Title</div>
          </div>
          <div class="mb-3">
            <div class="small text-muted">Eslogan</div>
            <div class="fw-semibold">@Model.TagLine</div>
          </div>
          <div class="mb-3">
            <div class="small text-muted">Descripción</div>
            <div class="text-muted">@Model.Description</div>
          </div>
          <div class="small text-muted">
            Las especialidades que se muestran en inicio se gestionan desde la sección de especialidades.
          </div>
        </div>
      </div>
    </div>

    <div class="col-12">
      <button type="submit" class="btn btn-primary">Guardar cambios</button>
    </div>
  </form>
</div>
