@page "/app/admin/reports"
@model CaveroSalud.Api.Pages.App.AdminReportsModel
@{
  ViewData["Title"] = "Reportes";
}

<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h3 mb-0">Reportes</h1>
      <div class="small text-muted">Gráficos y filtros por día, mes y año</div>
    </div>
    <a class="btn btn-outline-secondary" href="/app/admin">Volver al panel</a>
  </div>

  <form method="get" class="card shadow-sm mb-4">
    <div class="card-body row g-3 align-items-end">
      <div class="col-md-4">
        <label asp-for="FilterType" class="form-label">Agrupar por</label>
        <select asp-for="FilterType" class="form-select">
          <option value="day">Día</option>
          <option value="month">Mes</option>
          <option value="year">Año</option>
        </select>
      </div>
      <div class="col-md-4">
        <label asp-for="From" class="form-label">Desde</label>
        <input asp-for="From" class="form-control" type="date" />
      </div>
      <div class="col-md-4">
        <label asp-for="To" class="form-label">Hasta</label>
        <input asp-for="To" class="form-control" type="date" />
      </div>
      <div class="col-12">
        <button type="submit" class="btn btn-primary">Generar reporte</button>
      </div>
    </div>
  </form>

  <div class="row g-3 mb-4">
    <div class="col-md-3"><div class="card shadow-sm p-3"><div class="small text-muted">Usuarios</div><div class="h4 mb-0">@Model.UsersCount</div></div></div>
    <div class="col-md-3"><div class="card shadow-sm p-3"><div class="small text-muted">Citas</div><div class="h4 mb-0">@Model.AppointmentsCount</div></div></div>
    <div class="col-md-3"><div class="card shadow-sm p-3"><div class="small text-muted">Mensajes</div><div class="h4 mb-0">@Model.ContactMessagesCount</div></div></div>
    <div class="col-md-3"><div class="card shadow-sm p-3"><div class="small text-muted">Recetas</div><div class="h4 mb-0">@Model.PrescriptionsCount</div></div></div>
  </div>

  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <h5 class="card-title">Citas por periodo</h5>
      <canvas id="appointmentsChart" height="110"></canvas>
    </div>
  </div>

  <div class="card shadow-sm">
    <div class="card-body">
      <h5 class="card-title">Detalle filtrado</h5>
      <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
          <thead>
            <tr>
              <th>Periodo</th>
              <th class="text-end">Citas</th>
              <th class="text-end">Pacientes</th>
            </tr>
          </thead>
          <tbody>
            @foreach (var point in Model.Points)
            {
              <tr>
                <td>@point.Label</td>
                <td class="text-end">@point.Appointments</td>
                <td class="text-end">@point.Patients</td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

@section Scripts {
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
  <script>
    const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Points.Select(p => p.Label)));
    const values = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Points.Select(p => p.Appointments)));
    const ctx = document.getElementById('appointmentsChart');
    if (ctx) {
      new Chart(ctx, {
        type: 'bar',
        data: {
          labels,
          datasets: [{
            label: 'Citas',
            data: values,
            backgroundColor: '#0d6efd'
          }]
        },
        options: {
          responsive: true,
          plugins: { legend: { display: false } },
          scales: { y: { beginAtZero: true, ticks: { precision: 0 } } }
        }
      });
    }
  </script>
}
