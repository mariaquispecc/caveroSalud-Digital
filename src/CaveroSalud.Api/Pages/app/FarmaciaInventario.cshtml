@page "/app/farmacia/inventario"
@model CaveroSalud.Api.Pages.App.FarmaciaInventarioModel
@{
  ViewData["Title"] = "Inventario";
}

<div class="container py-5">
  @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
  {
    <div class="alert alert-success" role="alert">@Model.StatusMessage</div>
  }
  @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
  {
    <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
  }

  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h3 mb-0">Inventario</h1>
      <div class="small text-muted">Stock actual y alertas de reposición</div>

  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <h6 class="mb-3">Agregar medicamento</h6>
      <form method="post" asp-page-handler="Create" class="row g-2 align-items-end">
        <div class="col-md-4">
          <label asp-for="Input.Name" class="form-label">Medicamento</label>
          <input asp-for="Input.Name" class="form-control" />
        </div>
        <div class="col-md-2">
          <label asp-for="Input.Unit" class="form-label">Unidad</label>
          <input asp-for="Input.Unit" class="form-control" placeholder="und" />
        </div>
        <div class="col-md-2">
          <label asp-for="Input.Quantity" class="form-label">Cantidad</label>
          <input asp-for="Input.Quantity" type="number" min="0" step="0.01" class="form-control" />
        </div>
        <div class="col-md-2">
          <label asp-for="Input.MinThreshold" class="form-label">Stock mínimo</label>
          <input asp-for="Input.MinThreshold" type="number" min="0" step="0.01" class="form-control" />
        </div>
        <div class="col-md-2">
          <button type="submit" class="btn btn-primary w-100">Guardar</button>
        </div>
      </form>
    </div>
  </div>
    </div>
    <a class="btn btn-outline-secondary" href="/app/farmacia">Volver al panel</a>
  </div>

  <div class="card shadow-sm">
    <div class="card-body">
      <div class="table-responsive">
        <table class="table table-striped align-middle mb-0">
          <thead>
            <tr>
              <th>Medicamento</th>
              <th>Unidad</th>
              <th class="text-end">Cantidad</th>
              <th class="text-end">Mínimo</th>
            </tr>
          </thead>
          <tbody>
            @foreach (var item in Model.Items)
            {
              <tr>
                <td class="fw-semibold">@item.Name</td>
                <td>@item.Unit</td>
                <td class="text-end">@item.Quantity</td>
                <td class="text-end">@item.MinThreshold</td>
              </tr>
            }
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
