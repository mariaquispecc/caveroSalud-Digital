@page "/app/admin/specialities"
@model CaveroSalud.Api.Pages.App.AdminSpecialitiesModel
@{
  ViewData["Title"] = "Especialidades";
}

<div class="container py-5">
  @if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
  {
    <div class="alert alert-success" role="alert">@Model.StatusMessage</div>
  }
  @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
  {
    <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
  }

  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h3 mb-0">Sección especialidades</h1>
      <div class="small text-muted">CRUD de especialidades. Solo las activas se muestran en inicio.</div>
    </div>
    <a class="btn btn-outline-secondary" href="/app/admin">Volver al panel</a>
  </div>

  <div class="row g-4">
    <div class="col-lg-4">
      <div class="card shadow-sm">
        <div class="card-body">
          <h5 class="card-title">@((Model.EditId.HasValue ? "Editar especialidad" : "Crear especialidad"))</h5>
          <form method="post" asp-page-handler="Save" class="vstack gap-3 mt-3">
            <input type="hidden" asp-for="EditId" />
            <div>
              <label asp-for="Name" class="form-label">Nombre</label>
              <input asp-for="Name" class="form-control" />
            </div>
            <div>
              <label asp-for="Description" class="form-label">Descripción</label>
              <textarea asp-for="Description" class="form-control" rows="4"></textarea>
            </div>
            <div class="form-check">
              <input asp-for="IsActive" class="form-check-input" />
              <label asp-for="IsActive" class="form-check-label">Activa</label>
            </div>
            <div class="d-flex gap-2">
              <button type="submit" class="btn btn-primary">Guardar</button>
              @if (Model.EditId.HasValue)
              {
                <a class="btn btn-outline-secondary" href="/app/admin/specialities">Cancelar</a>
              }
            </div>
          </form>
        </div>
      </div>
    </div>

    <div class="col-lg-8">
      <div class="card shadow-sm">
        <div class="card-body">
          <div class="table-responsive">
            <table class="table table-striped align-middle mb-0">
              <thead>
                <tr>
                  <th>Nombre</th>
                  <th>Descripción</th>
                  <th>Estado</th>
                  <th class="text-end">Acciones</th>
                </tr>
              </thead>
              <tbody>
                @foreach (var speciality in Model.Specialities)
                {
                  <tr>
                    <td class="fw-semibold">@speciality.Name</td>
                    <td>@speciality.Description</td>
                    <td>
                      @if (speciality.IsActive)
                      {
                        <span class="badge text-bg-success">Activa</span>
                      }
                      else
                      {
                        <span class="badge text-bg-secondary">Inactiva</span>
                      }
                    </td>
                    <td class="text-end">
                      <a class="btn btn-sm btn-outline-primary me-2" href="/app/admin/specialities?editId=@speciality.Id">Editar</a>
                      <form method="post" asp-page-handler="Delete" class="d-inline" onsubmit="return confirm('¿Eliminar esta especialidad?');">
                        <input type="hidden" name="id" value="@speciality.Id" />
                        <button type="submit" class="btn btn-sm btn-outline-danger">Eliminar</button>
                      </form>
                    </td>
                  </tr>
                }
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
