<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>@ViewData["Title"] - CaveroSalud</title>
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" integrity="sha512-iecdLmaskl7CVkqkXNQ/ZH/XLlvWZOJyj7Yy7tcenmpD1ypASozpmT/E0iPtmFIB46ZmdtAc9eNBvH0H/ZpiBw==" crossorigin="anonymous">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-T3c6CoIi6uLrA9TneNEoa7RxnatzjcDSCmG1MXxSR1GAsXEV/Dwwykc2MPK8M2HN" crossorigin="anonymous">
  <link href="/public/css/site.min.css" rel="stylesheet">
  <link href="/public/css/site.css" rel="preload" as="style" onload="this.rel='stylesheet'">
  <link rel="icon" href="/public/img/favicon.svg" type="image/svg+xml">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm" aria-label="Barra superior">
    <div class="container">
      @{ 
        var panelUrl = "/login";
        var panelLabel = "Iniciar sesión";

        if (User.Identity?.IsAuthenticated == true)
        {
          if (User.IsInRole("Administrador") || User.IsInRole("Admin"))
          {
            panelUrl = "/app/admin";
            panelLabel = "Mi panel";
          }
          else if (User.IsInRole("Paciente"))
          {
            panelUrl = "/app/paciente";
            panelLabel = "Mi panel";
          }
          else if (User.IsInRole("Médico") || User.IsInRole("Medico"))
          {
            panelUrl = "/app/medico";
            panelLabel = "Mi panel";
          }
          else if (User.IsInRole("Laboratorista"))
          {
            panelUrl = "/app/laboratorio";
            panelLabel = "Mi panel";
          }
          else if (User.IsInRole("Farmacéutico") || User.IsInRole("Farmaceutico"))
          {
            panelUrl = "/app/farmacia";
            panelLabel = "Mi panel";
          }
        }
      }
      <a class="skip-link visually-hidden-focusable" href="#main-content">Saltar al contenido</a>
      <a class="navbar-brand d-flex align-items-center fw-bold" href="/">
        <img src="/public/img/logo.png" alt="Clínica Cavero" class="navbar-logo me-2" width="34" height="34" />
        Clínica Cavero
      </a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu" aria-controls="navMenu" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <nav class="collapse navbar-collapse" id="navMenu" aria-label="Menú principal">
        <ul class="navbar-nav ms-auto mb-2 mb-lg-0 align-items-center">
          <li class="nav-item"><a class="nav-link" href="/#">Inicio</a></li>
          <li class="nav-item"><a class="nav-link" href="/#about">Nosotros</a></li>
          <li class="nav-item"><a class="nav-link" href="/#services">Servicios</a></li>
          <li class="nav-item"><a class="nav-link" href="/#specialties">Especialidades</a></li>
          <li class="nav-item"><a class="nav-link" href="/#contact">Contacto</a></li>
          @if (User.Identity?.IsAuthenticated == true)
          {
            <li class="nav-item"><a class="btn btn-outline-primary btn-sm me-2 mt-3 mt-lg-0" href="@panelUrl">@panelLabel</a></li>
          }
          <li class="nav-item nav-auth-group d-flex align-items-center mt-3 mt-lg-0">
            @if (User.Identity?.IsAuthenticated == true)
            {
              <form method="post" asp-page="/Logout" class="d-inline">
                <button type="submit" class="btn btn-outline-danger btn-sm">Cerrar sesión</button>
              </form>
            }
            else
            {
              <a class="btn btn-outline-primary btn-sm me-2" href="/login"><i class="fa-solid fa-right-to-bracket me-1"></i>Iniciar sesión</a>
              <a class="btn btn-primary btn-sm" href="/register"><i class="fa-solid fa-user-plus me-1"></i>Registrarse</a>
            }
          </li>
        </ul>
      </nav>
    </div>
  </nav>

  <main id="main-content" role="main" class="py-4">
    <div class="container">
      @RenderBody()
    </div>
  </main>

  <footer class="bg-dark text-white py-5">
    <div class="container">
      <div class="row gy-4">
        <div class="col-md-4">
          <h3 class="h5 text-white">Clínica Cavero</h3>
          <p class="text-muted">Tu salud es nuestra prioridad. Ofrecemos servicios médicos integrales con calidad y calidez.</p>
        </div>
        <div class="col-md-4">
          <h3 class="h5 text-white">Enlaces Rápidos</h3>
          <ul class="list-unstyled">
            <li><a href="/#" class="text-muted text-decoration-none">Inicio</a></li>
            <li><a href="/#about" class="text-muted text-decoration-none">Nosotros</a></li>
            <li><a href="/#services" class="text-muted text-decoration-none">Servicios</a></li>
            <li><a href="/#specialties" class="text-muted text-decoration-none">Especialidades</a></li>
            <li><a href="/#contact" class="text-muted text-decoration-none">Contacto</a></li>
          </ul>
        </div>
        <div class="col-md-4">
          <h3 class="h5 text-white">Contacto</h3>
          <p class="mb-1"><i class="fa-solid fa-location-dot me-2"></i>Ayacucho, Perú</p>
          <p class="mb-1"><i class="fa-solid fa-phone me-2"></i>+51 966 123 456</p>
          <p class="mb-1"><i class="fa-solid fa-envelope me-2"></i>info@clinicacavero.pe</p>
          <p class="mb-1"><i class="fa-solid fa-globe me-2"></i>www.clinicacavero.pe</p>
        </div>
      </div>
      <div class="border-top mt-4 pt-3 text-muted small">© 2026 Clínica Cavero EIRL - RUC N° 20564091571 - Todos los derechos reservados.</div>
    </div>
  </footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" integrity="sha384-C6RzsynM9kWDrMNeT87bh95OGNyZPhcTNXj1NW7RuBCsyN/o0jlpcV8Qyq46cDfL" crossorigin="anonymous"></script>
  @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
