@page "/admin/settings"
@model CaveroSalud.Api.Pages.Admin.SettingsModel
@{
  ViewData["Title"] = "Configuración del sitio";
}

<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h3 mb-0">Configuración del sitio</h1>
      <div class="small text-muted">Ajustes rápidos del portal</div>
    </div>
    <a class="btn btn-outline-secondary" href="/app/admin">Volver al panel</a>
  </div>

  <div class="row g-3">
    <div class="col-lg-4"><div class="card shadow-sm h-100"><div class="card-body"><h6>Identidad</h6><p class="text-muted mb-0">Acceso por roles, login y registro habilitados.</p></div></div></div>
    <div class="col-lg-4"><div class="card shadow-sm h-100"><div class="card-body"><h6>Contenido público</h6><p class="text-muted mb-0">Las páginas de inicio, contacto y servicios se sirven desde Razor Pages.</p></div></div></div>
    <div class="col-lg-4"><div class="card shadow-sm h-100"><div class="card-body"><h6>Seguridad</h6><p class="text-muted mb-0">Las sesiones usan autenticación de cookies de ASP.NET Identity.</p></div></div></div>
  </div>
</div>
